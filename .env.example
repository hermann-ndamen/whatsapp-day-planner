# -----------------------------------------------------------------------------
# WhatsApp Day Planner — environment
# Copy to .env and fill in. Never commit the real .env.
# -----------------------------------------------------------------------------

# --- Anthropic (the planning agent) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLANNER_MODEL=claude-opus-4-8

# --- WhatsApp Cloud API (Meta / Graph API) ---
# From Meta > WhatsApp > API Setup
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=000000000000000
# A random string you invent; you also enter it in the webhook config screen
WHATSAPP_VERIFY_TOKEN=choose-a-long-random-string
# The number the planner texts, E.164 digits only, no '+', e.g. 15551234567
WHATSAPP_RECIPIENT=15551234567
WHATSAPP_GRAPH_VERSION=v21.0

# --- Notion ---
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Schedule database (or data source) id — share the DB with your integration
NOTION_SCHEDULE_DB=00000000000000000000000000000000
# Optional: a database for daily reflections / logs
NOTION_LOG_DB=

# --- Behaviour ---
# IANA timezone name; all scheduling math is done in this local time
PLANNER_TIMEZONE=America/New_York
# Only these categories get proactive check-ins (comma separated)
CHECKIN_CATEGORIES=Deep Work,Learning,Writing,Admin,Exercise
# Do-not-disturb window (local 24h hours); no check-ins fire inside it
QUIET_START_HOUR=22
QUIET_END_HOUR=7
